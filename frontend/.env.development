# Development Environment (Overrides .env in development mode)
# Use this for development-specific configuration

VITE_PORT=5173

VITE_API_URL=http://localhost:8080

VITE_APP_NAME=Continuum Research (Dev)
VITE_APP_ENV=development

VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

VITE_GOOGLE_CLIENT_ID=

VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

VITE_AUTH_BASE=/auth
VITE_API_BASE=/api

VITE_API_TIMEOUT=30000
VITE_AUTO_SAVE_DELAY=2000

VITE_DEBUG=true
VITE_LOG_LEVEL=debug
