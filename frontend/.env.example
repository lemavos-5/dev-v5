# Copy this file to .env.local and fill the values for your local development environment.

# Primary backend API URL used by the frontend.
VITE_API_URL=http://localhost:8080
# Legacy alias for compatibility. Keep in sync with VITE_API_URL if used.
VITE_FRONTEND_FORGE_API_URL=http://localhost:8080

# Google Maps API key used by the map component.
VITE_FRONTEND_FORGE_API_KEY=your-google-maps-api-key

# OAuth provider values.
VITE_OAUTH_PORTAL_URL=http://localhost:3001
VITE_APP_ID=local-app-123

# App branding.
VITE_APP_TITLE=Continuum
VITE_APP_LOGO=https://cdn.example.com/logo.png
VITE_GOOGLE_MAP_ID=DEMO_MAP_ID

# Optional analytics values.
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-umami-website-id
