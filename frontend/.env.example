# Environment Configuration Example
# Copy this file to .env, .env.development, or .env.production
# and fill in the appropriate values

# Development Server
VITE_PORT=5173

# API Configuration
VITE_API_URL=http://localhost:8080

# Application Configuration
VITE_APP_NAME=Continuum Research
VITE_APP_ENV=development

# Stripe Configuration
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Google OAuth Configuration (optional)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# API Endpoints (relative to API_URL or override if needed)
VITE_AUTH_BASE=/auth
VITE_API_BASE=/api

# Timeouts and Performance
VITE_API_TIMEOUT=30000
VITE_AUTO_SAVE_DELAY=2000

# Development
VITE_DEBUG=false
VITE_LOG_LEVEL=info
