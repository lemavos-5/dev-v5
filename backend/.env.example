# ---- Produção (MongoDB as source-of-truth) ----
SPRING_DATA_MONGODB_URI=mongodb://usuario:senha@host:27017/continuum?authSource=admin
SERVER_PORT=8080
APP_URL=https://app.seusite.com

# ---- JWT ----
JWT_SECRET=insira_uma_chave_256_bits_aqui
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
JWT_EXPIRATION=900000

# ---- Email ----
RESEND_API_KEY=
EMAIL_FROM=noreply@continuum.com
EMAIL_VERIFICATION_URL=https://app.seusite.com/verify-email

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PLUS=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_VISION=price_...
STRIPE_SUCCESS_URL=https://app.seusite.com/subscription/success
STRIPE_CANCEL_URL=https://app.seusite.com/subscription/cancel

# ---- Planos (opcional; pode sobrepor plan.*)
PLAN_FREE_MAX_ENTITIES=20
PLAN_FREE_MAX_NOTES=50
PLAN_FREE_MAX_HABITS=3
PLAN_FREE_MAX_HISTORY_DAYS=30
PLAN_FREE_MAX_METADATA_KB=10
PLAN_FREE_MAX_VAULT_SIZE_MB=100

PLAN_PLUS_MAX_ENTITIES=100
PLAN_PLUS_MAX_NOTES=500
PLAN_PLUS_MAX_HABITS=10
PLAN_PLUS_MAX_HISTORY_DAYS=180
PLAN_PLUS_MAX_METADATA_KB=50
PLAN_PLUS_MAX_VAULT_SIZE_MB=1024

PLAN_PRO_MAX_ENTITIES=-1
PLAN_PRO_MAX_NOTES=-1
PLAN_PRO_MAX_HABITS=-1
PLAN_PRO_MAX_HISTORY_DAYS=730
PLAN_PRO_MAX_METADATA_KB=500
PLAN_PRO_MAX_VAULT_SIZE_MB=2048

PLAN_GOLD_MAX_ENTITIES=-1
PLAN_GOLD_MAX_NOTES=-1
PLAN_GOLD_MAX_HABITS=-1
PLAN_GOLD_MAX_HISTORY_DAYS=-1
PLAN_GOLD_MAX_METADATA_KB=2048
PLAN_GOLD_MAX_VAULT_SIZE_MB=4096

# ---- CORS / OAuth / Vault B2 ----
CORS_ALLOWED_ORIGINS=https://app.seusite.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.seusite.com/auth/google/callback
VAULT_B2_ENDPOINT=s3.us-east-005.backblazeb2.com
VAULT_B2_BUCKET=nome-do-bucket
VAULT_B2_ACCESS_KEY=
VAULT_B2_SECRET_KEY=
VAULT_B2_REGION=us-east-005
